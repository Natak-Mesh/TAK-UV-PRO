<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#E6000000">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Packet Terminal"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/terminal_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Radio: DISCONNECTED   Session: IDLE   Remote: N/A"
        android:textColor="#B0BEC5"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/terminal_remote_call"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Remote Call (e.g. WL2K)"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#FF666666"
            android:background="#FF1B1B1B"
            android:padding="8dp"
            android:singleLine="true"
            android:inputType="textNoSuggestions|textVisiblePassword" />

        <EditText
            android:id="@+id/terminal_remote_ssid"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:hint="SSID"
            android:text="0"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#FF666666"
            android:background="#FF1B1B1B"
            android:padding="8dp"
            android:singleLine="true"
            android:inputType="number" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/terminal_connect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connect"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF455A64" />

        <Button
            android:id="@+id/terminal_disconnect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Disconnect"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF455A64" />

        <Button
            android:id="@+id/terminal_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Clear"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF455A64" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:fillViewport="true"
        android:background="#FF1B1B1B">

        <TextView
            android:id="@+id/terminal_transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:textIsSelectable="true" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/terminal_line_input"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Type line and send"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#FF666666"
            android:background="#FF1B1B1B"
            android:padding="8dp"
            android:singleLine="true"
            android:inputType="textNoSuggestions|textVisiblePassword" />

        <Button
            android:id="@+id/terminal_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Send"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF1976D2" />
    </LinearLayout>
</LinearLayout>
